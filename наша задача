code
Python
#!/usr/bin/env python3
import sys
import struct
import subprocess
import argparse

def set_config(mode, port, normal_mbps, penalty_mbps, burst_mb, win_sec, pen_sec):
    normal_bps = int((normal_mbps * 1024 * 1024) / 8)
    penalty_bps = int((penalty_mbps * 1024 * 1024) / 8)
    burst_bytes = int(burst_mb * 1024 * 1024)
    win_ns = int(win_sec * 1000000000)
    pen_ns = int(pen_sec * 1000000000)

    # I = u32 (4 байта), Q = u64 (8 байт)
    # mode(I), port(I), rate(Q), pen_rate(Q), burst(Q), win(Q), pen(Q)
    payload = struct.pack("<I I Q Q Q Q Q", 
                          mode, port, normal_bps, penalty_bps, 
                          burst_bytes, win_ns, pen_ns)
    
    hex_str = " ".join([f"{b:02x}" for b in payload])
    cmd = f"bpftool map update name config_map key hex 00 00 00 00 value hex {hex_str}"
    
    subprocess.run(cmd, shell=True, check=True)
    
    port_str = f"ПОРТ: {port}" if port > 0 else "ВСЕ ПОРТЫ"
    print(f"✅ Успешно! Режим: {mode} | {port_str} | Скорость: {normal_mbps} Мбит/с")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="eBPF Контроллер")
    parser.add_argument("--mode", type=int, required=True, help="1=Статика, 2=Динамика")
    parser.add_argument("--port", type=int, default=0, help="Целевой порт (0 = все)")
    parser.add_argument("--speed", type=float, required=True, help="Обычная скорость (Мбит/с)")
    parser.add_argument("--pspeed", type=float, default=10, help="Скорость штрафа (Мбит/с)")
    parser.add_argument("--burst", type=float, default=70, help="Лимит до штрафа (МБ)")
    parser.add_argument("--win", type=int, default=10, help="Окно времени (сек)")
    parser.add_argument("--pen", type=int, default=60, help="Время штрафа (сек)")
    
    args = parser.parse_args()
    set_config(args.mode, args.port, args.speed, args.pspeed, args.burst, args.win, args.pen)
Шаг 3: Как вызывать это из твоего Bash-меню
Теперь ты можешь менять правила и привязывать их к конкретному порту на лету!
Пример 1: Ограничить ВСЁ (любые порты) до 50 Мбит/с:
code
Bash
./reshala_ctrl.py --mode 1 --port 0 --speed 50
Пример 2: Ограничить ТОЛЬКО порт 443 (Динамика), а 8443 будет работать безлимитно:
code
Bash
# Трафик на 443 порт будет резаться. Трафик на 8443 порт eBPF просто проигнорирует.
./reshala_ctrl.py --mode 2 --port 443 --speed 100 --pspeed 10 --burst 70
🧠 Важный нюанс про Upload (Загрузку от пользователя к серверу)
Поскольку ты хочешь резать и скачивание (Download), и загрузку (Upload), тебе нужно будет загрузить этот же .o файл дважды:
На eth0 egress (для Download, пакеты уходят от сервера к юзеру).
На ifb0 egress (для Upload, пакеты перенаправлены с eth0 ingress).
Так как мы загружаем программу два раза в разные интерфейсы, ядро создаст две независимые BPF карты (одну для eth0, другую для ifb0). Это супер круто, потому что:
Ты сможешь установить разные лимиты! (Например: Download = Режим 2, а Upload = Режим 1).
Статистика (сколько скачано, сколько загружено) не будет смешиваться.
В твоем Bash скрипте тебе просто нужно будет вызывать bpftool, указывая ID нужной карты (поищем её через bpftool map), чтобы обновлять конфиг для Upload и Download по отдельности. Но об этой «косметике» в Bash мы можем поговорить на следующем этапе, если код выше тебе понятен и нравится!