🧠 Архитектура: как это будет работать?
Мы создадим 2 карты (BPF Maps):
config_map — здесь Bash-скрипт задает настройки: режим работы, лимиты, время.
user_state_map — здесь eBPF сам хранит статистику по каждому IP (сколько скачал, когда начал, находится ли под штрафом).
Режимы работы, которые мы реализуем:
Режим 1 (Статика): Жесткий лимит скорости для всех (например, 50 Мбит/с).
Режим 2 (Динамика / Burst): Качай на максимальной скорости (например, 100 Мбит/с), но если за 10 секунд выкачал больше 70 МБ, скорость режется до 10 Мбит/с на следующие 60 секунд (штраф).
1️⃣ Код на C (eBPF Движок)
Этот код пишется в файл shaper.c и компилируется один раз. Обрати внимание: здесь нет ни одной захардкоженной цифры. Все берется из config_map.
(Это концептуальный рабочий скелет алгоритма Token Bucket с квотами)
code
C
#include <linux/bpf.h>
#include <linux/pkt_cls.h>
#include <linux/if_ether.h>
#include <linux/ip.h>
#include <bpf/bpf_helpers.h>

// --- Структура настроек (Заполняется из Bash) ---
struct config_data {
    __u32 mode;                // 1 = Статика, 2 = Динамика
    __u64 normal_rate_bps;     // Обычная скорость (байт/сек)
    __u64 penalty_rate_bps;    // Скорость в штрафе (байт/сек)
    __u64 burst_bytes_limit;   // Лимит трафика (например, 70 МБ)
    __u64 window_time_ns;      // Окно времени (например, 10 сек)
    __u64 penalty_time_ns;     // Время штрафа (например, 60 сек)
};

// --- Структура состояния юзера (Заполняется ядром) ---
struct user_state {
    __u64 bytes_in_window;     // Сколько байт скачал в текущем окне
    __u64 window_start_time;   // Когда началось окно
    __u32 is_penalized;        // 1 = оштрафован, 0 = всё ок
    __u64 penalty_end_time;    // Когда закончится штраф
    __u64 tokens;              // Для алгоритма ограничения скорости
    __u64 last_packet_time;    // Время последнего пакета
};

// --- Инициализация BPF Карт ---
struct {
    __uint(type, BPF_MAP_TYPE_ARRAY);
    __uint(max_entries, 1);
    __type(key, __u32);
    __type(value, struct config_data);
} config_map SEC(".maps");

struct {
    __uint(type, BPF_MAP_TYPE_HASH);
    __uint(max_entries, 10000); // До 10 000 уникальных IP
    __type(key, __u32);         // IP адрес
    __type(value, struct user_state);
} user_state_map SEC(".maps");


SEC("classifier")
int handle_traffic(struct __sk_buff *skb) {
    // 1. Читаем настройки из карты
    __u32 conf_key = 0;
    struct config_data *conf = bpf_map_lookup_elem(&config_map, &conf_key);
    if (!conf) return TC_ACT_OK; // Если настроек нет, пропускаем всё

    // 2. Достаем IP адрес (упрощенно для IPv4)
    void *data = (void *)(long)skb->data;
    void *data_end = (void *)(long)skb->data_end;
    struct ethhdr *eth = data;
    if ((void *)(eth + 1) > data_end) return TC_ACT_OK;
    
    struct iphdr *ip = (struct iphdr *)(eth + 1);
    if ((void *)(ip + 1) > data_end) return TC_ACT_OK;
    __u32 src_ip = ip->saddr; // Или daddr, смотря куда вешаем (Upload/Download)

    // 3. Достаем состояние юзера по его IP
    struct user_state *state = bpf_map_lookup_elem(&user_state_map, &src_ip);
    __u64 now = bpf_ktime_get_ns(); // Текущее время в наносекундах
    __u32 packet_len = skb->len;

    // Если юзер новый - инициализируем его
    if (!state) {
        struct user_state new_state = {
            .window_start_time = now,
            .last_packet_time = now,
            .tokens = conf->normal_rate_bps // Стартовый буфер
        };
        bpf_map_update_elem(&user_state_map, &src_ip, &new_state, BPF_ANY);
        return TC_ACT_OK;
    }

    // ==========================================
    // ЛОГИКА РЕЖИМА 2 (ДИНАМИКА)
    // ==========================================
    if (conf->mode == 2) {
        // Проверяем, вышел ли срок штрафа
        if (state->is_penalized && now > state->penalty_end_time) {
            state->is_penalized = 0; // Снимаем штраф
            state->window_start_time = now;
            state->bytes_in_window = 0;
        }

        // Если не оштрафован, считаем трафик
        if (!state->is_penalized) {
            // Если окно (10 сек) прошло, сбрасываем счетчик
            if (now - state->window_start_time > conf->window_time_ns) {
                state->window_start_time = now;
                state->bytes_in_window = 0;
            }

            state->bytes_in_window += packet_len;

            // Если превысил 70 МБ за окно -> ДАЕМ ШТРАФ
            if (state->bytes_in_window > conf->burst_bytes_limit) {
                state->is_penalized = 1;
                state->penalty_end_time = now + conf->penalty_time_ns;
            }
        }
    }

    // ==========================================
    // ЛОГИКА ОГРАНИЧЕНИЯ СКОРОСТИ (Token Bucket)
    // ==========================================
    __u64 current_rate = conf->normal_rate_bps;
    if (conf->mode == 2 && state->is_penalized) {
        current_rate = conf->penalty_rate_bps; // Режем скорость до 10 Мбит/с
    }

    // Пополняем токены (зависит от прошедшего времени)
    __u64 time_passed = now - state->last_packet_time;
    state->tokens += (time_passed * current_rate) / 1000000000;
    if (state->tokens > current_rate) state->tokens = current_rate; // Максимум 1 секунда буфера

    state->last_packet_time = now;

    // Если токенов хватает - пропускаем пакет, иначе - дропаем
    if (state->tokens >= packet_len) {
        state->tokens -= packet_len;
        return TC_ACT_OK;   // Пропускаем пакет
    } else {
        return TC_ACT_SHOT; // Дропаем пакет (Шейпинг сработал)
    }
}
