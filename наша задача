code
Python
#!/usr/bin/env python3
import sys
import struct
import subprocess
import argparse

def set_config(mode, normal_mbps, penalty_mbps, burst_mb, win_sec, pen_sec):
    # Переводим мегабиты и мегабайты в БАЙТЫ и НАНОСЕКУНДЫ
    normal_bps = int((normal_mbps * 1024 * 1024) / 8)
    penalty_bps = int((penalty_mbps * 1024 * 1024) / 8)
    burst_bytes = int(burst_mb * 1024 * 1024)
    win_ns = int(win_sec * 1000000000)
    pen_ns = int(pen_sec * 1000000000)

    # Упаковываем в бинарную структуру C (Little Endian)
    # I = 4 байта (u32), Q = 8 байт (u64)
    payload = struct.pack("<I I Q Q Q Q Q", 
                          mode, 0, normal_bps, penalty_bps, 
                          burst_bytes, win_ns, pen_ns)
    
    # Конвертируем в hex строку для bpftool
    hex_str = " ".join([f"{b:02x}" for b in payload])
    
    cmd = f"bpftool map update name config_map key hex 00 00 00 00 value hex {hex_str}"
    subprocess.run(cmd, shell=True, check=True)
    print(f"✅ Настройки применены! Режим: {mode}, Скорость: {normal_mbps} Мбит/с")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Управление eBPF шейпером")
    parser.add_argument("--mode", type=int, required=True, help="1=Статика, 2=Динамика")
    parser.add_argument("--speed", type=float, required=True, help="Нормальная скорость (Мбит/с)")
    parser.add_argument("--pspeed", type=float, default=10, help="Скорость штрафа (Мбит/с)")
    parser.add_argument("--burst", type=float, default=70, help="Лимит трафика до штрафа (МБ)")
    parser.add_argument("--win", type=int, default=10, help="Окно времени (сек)")
    parser.add_argument("--pen", type=int, default=60, help="Время штрафа (сек)")
    
    args = parser.parse_args()
    set_config(args.mode, args.speed, args.pspeed, args.burst, args.win, args.pen)
