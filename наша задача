#include <linux/bpf.h>
#include <linux/pkt_cls.h>
#include <linux/if_ether.h>
#include <linux/ip.h>
#include <linux/ipv6.h>
#include <linux/tcp.h>
#include <linux/udp.h>
#include <bpf/bpf_helpers.h>
#include <bpf/bpf_endian.h>

// --- Структура настроек ---
struct config_data {
    __u32 mode;                // 1 = Статика, 2 = Динамика
    __u32 target_port;         // Целевой порт (0 = Все порты). Заменил _pad!
    __u64 normal_rate_bps;     // Обычная скорость (байт/сек)
    __u64 penalty_rate_bps;    // Скорость в штрафе (байт/сек)
    __u64 burst_bytes_limit;   // Лимит трафика (байт)
    __u64 window_time_ns;      // Окно времени (нс)
    __u64 penalty_time_ns;     // Время штрафа (нс)
};

struct ip_key {
    __u32 addr[4]; 
};

struct user_state {
    __u64 bytes_in_window;
    __u64 window_start_time;
    __u64 penalty_end_time;
    __u64 last_departure_time;
    __u64 total_bytes;
    __u32 is_penalized;
    __u32 _pad;
};

struct {
    __uint(type, BPF_MAP_TYPE_ARRAY);
    __uint(max_entries, 1);
    __type(key, __u32);
    __type(value, struct config_data);
} config_map SEC(".maps");

struct {
    __uint(type, BPF_MAP_TYPE_HASH);
    __uint(max_entries, 65536);
    __type(key, struct ip_key);
    __type(value, struct user_state);
} user_state_map SEC(".maps");

SEC("classifier")
int handle_traffic(struct __sk_buff *skb) {
    __u32 conf_key = 0;
    struct config_data *conf = bpf_map_lookup_elem(&config_map, &conf_key);
    if (!conf || conf->mode == 0) return TC_ACT_OK; // Шейпер выключен

    void *data = (void *)(long)skb->data;
    void *data_end = (void *)(long)skb->data_end;
    struct ethhdr *eth = data;
    if ((void *)(eth + 1) > data_end) return TC_ACT_OK;

    struct ip_key ip_k = {};
    __u16 sport = 0, dport = 0;
    __u8 protocol = 0;
    void *trans_hdr = NULL;

    // --- ПАРСИНГ IPv4 и IPv6 ---
    if (eth->h_proto == bpf_htons(ETH_P_IP)) {
        struct iphdr *ip = (struct iphdr *)(eth + 1);
        if ((void *)(ip + 1) > data_end) return TC_ACT_OK;
        
        ip_k.addr[0] = ip->saddr;
        protocol = ip->protocol;
        trans_hdr = (void *)ip + (ip->ihl * 4); // Прыгаем к TCP/UDP заголовку
        
    } else if (eth->h_proto == bpf_htons(ETH_P_IPV6)) {
        struct ipv6hdr *ipv6 = (struct ipv6hdr *)(eth + 1);
        if ((void *)(ipv6 + 1) > data_end) return TC_ACT_OK;
        
        __builtin_memcpy(ip_k.addr, ipv6->saddr.in6_u.u6_addr32, 16);
        protocol = ipv6->nexthdr;
        trans_hdr = (void *)(ipv6 + 1);
    } else {
        return TC_ACT_OK;
    }

    // --- ПАРСИНГ ПОРТОВ (TCP / UDP) ---
    if (protocol == IPPROTO_TCP) {
        struct tcphdr *tcp = (struct tcphdr *)trans_hdr;
        if ((void *)(tcp + 1) <= data_end) {
            sport = bpf_ntohs(tcp->source);
            dport = bpf_ntohs(tcp->dest);
        }
    } else if (protocol == IPPROTO_UDP) {
        struct udphdr *udp = (struct udphdr *)trans_hdr;
        if ((void *)(udp + 1) <= data_end) {
            sport = bpf_ntohs(udp->source);
            dport = bpf_ntohs(udp->dest);
        }
    }

    // === ЛОГИКА ФИЛЬТРАЦИИ ПО ПОРТУ ===
    // Если в конфиге задан конкретный порт, и ни порт отправителя, ни порт получателя 
    // не совпадают с ним — пропускаем пакет без ограничений!
    if (conf->target_port != 0) {
        if (sport != conf->target_port && dport != conf->target_port) {
            return TC_ACT_OK; 
        }
    }

    // Дальше идет стандартная логика шейпера (из предыдущего сообщения)
    struct user_state *state = bpf_map_lookup_elem(&user_state_map, &ip_k);
    __u64 now = bpf_ktime_get_ns();
    __u32 packet_len = skb->len;

    if (!state) {
        struct user_state new_state = {
            .window_start_time = now,
            .last_departure_time = now,
            .total_bytes = packet_len
        };
        bpf_map_update_elem(&user_state_map, &ip_k, &new_state, BPF_ANY);
        return TC_ACT_OK;
    }

    __sync_fetch_and_add(&state->total_bytes, packet_len);

    if (conf->mode == 2) {
        if (state->is_penalized && now > state->penalty_end_time) {
            state->is_penalized = 0;
            state->window_start_time = now;
            state->bytes_in_window = 0;
        }

        if (!state->is_penalized) {
            if (now - state->window_start_time > conf->window_time_ns) {
                state->window_start_time = now;
                state->bytes_in_window = 0;
            }
            state->bytes_in_window += packet_len;
            if (state->bytes_in_window > conf->burst_bytes_limit) {
                state->is_penalized = 1;
                state->penalty_end_time = now + conf->penalty_time_ns;
            }
        }
    }

    __u64 current_rate = conf->normal_rate_bps;
    if (conf->mode == 2 && state->is_penalized) {
        current_rate = conf->penalty_rate_bps;
    }

    if (current_rate == 0) return TC_ACT_OK;

    __u64 delay_ns = ((__u64)packet_len * 1000000000ULL) / current_rate;
    __u64 departure_time = state->last_departure_time;
    if (now > departure_time) departure_time = now;
    
    departure_time += delay_ns;

    if (departure_time - now > 2000000000ULL) return TC_ACT_SHOT;

    state->last_departure_time = departure_time;
    skb->tstamp = departure_time;

    return TC_ACT_OK;
}
