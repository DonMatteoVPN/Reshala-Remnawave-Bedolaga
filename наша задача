💡 Как работает EDT (В двух словах)?
Вместо того чтобы убивать лишние пакеты, eBPF рассчитывает, в какую микросекунду этот пакет должен быть отправлен, чтобы скорость была ровно 50 Мбит/с. Он вешает на пакет ярлык с этой меткой времени (skb->tstamp), а ядро Linux (очередь fq) само плавно задерживает отправку. Результат — идеально ровный график скорости и отсутствие скачков пинга.
Мы разобьем задачу на 3 файла. Скопируй их к себе.
Шаг 1: Идеальный eBPF-движок (C-код)
Создай файл shaper.bpf.c. Этот код поддерживает IPv4 и IPv6, использует EDT для плавного шейпинга и реализует оба твоих режима (Статика и Динамика).
code
C
#include <linux/bpf.h>
#include <linux/pkt_cls.h>
#include <linux/if_ether.h>
#include <linux/ip.h>
#include <linux/ipv6.h>
#include <bpf/bpf_helpers.h>

// --- Структура настроек ---
struct config_data {
    __u32 mode;                // 1 = Статика, 2 = Динамика
    __u32 _pad;                // Выравнивание для 64-битных систем
    __u64 normal_rate_bps;     // Обычная скорость (БАЙТ в секунду)
    __u64 penalty_rate_bps;    // Скорость при штрафе (БАЙТ в секунду)
    __u64 burst_bytes_limit;   // Лимит трафика до штрафа (БАЙТ)
    __u64 window_time_ns;      // Окно времени (Наносекунды)
    __u64 penalty_time_ns;     // Время штрафа (Наносекунды)
};

// --- Универсальный ключ IP (IPv4 и IPv6) ---
struct ip_key {
    __u32 addr[4]; // 16 байт: для IPv4 используем addr[0], для IPv6 - все 4
};

// --- Состояние пользователя ---
struct user_state {
    __u64 bytes_in_window;     // Скачано за текущее окно
    __u64 window_start_time;   // Начало окна
    __u64 penalty_end_time;    // Конец штрафа
    __u64 last_departure_time; // EDT (Время отправки последнего пакета)
    __u64 total_bytes;         // ОБЩАЯ СТАТИСТИКА (Счетчик для Bash)
    __u32 is_penalized;        // 1 = оштрафован
    __u32 _pad;
};

// --- BPF Карты ---
struct {
    __uint(type, BPF_MAP_TYPE_ARRAY);
    __uint(max_entries, 1);
    __type(key, __u32);
    __type(value, struct config_data);
} config_map SEC(".maps");

struct {
    __uint(type, BPF_MAP_TYPE_HASH);
    __uint(max_entries, 65536); // Поддержка до 65к юзеров
    __type(key, struct ip_key);
    __type(value, struct user_state);
} user_state_map SEC(".maps");

SEC("classifier")
int handle_traffic(struct __sk_buff *skb) {
    __u32 conf_key = 0;
    struct config_data *conf = bpf_map_lookup_elem(&config_map, &conf_key);
    if (!conf || conf->mode == 0) return TC_ACT_OK; // Выключено

    void *data = (void *)(long)skb->data;
    void *data_end = (void *)(long)skb->data_end;
    struct ethhdr *eth = data;
    if ((void *)(eth + 1) > data_end) return TC_ACT_OK;

    struct ip_key ip_k = {};
    
    // Парсим IPv4 и IPv6
    if (eth->h_proto == bpf_htons(ETH_P_IP)) {
        struct iphdr *ip = (struct iphdr *)(eth + 1);
        if ((void *)(ip + 1) > data_end) return TC_ACT_OK;
        ip_k.addr[0] = ip->saddr; // Или daddr, смотря куда вешаем
    } else if (eth->h_proto == bpf_htons(ETH_P_IPV6)) {
        struct ipv6hdr *ipv6 = (struct ipv6hdr *)(eth + 1);
        if ((void *)(ipv6 + 1) > data_end) return TC_ACT_OK;
        __builtin_memcpy(ip_k.addr, ipv6->saddr.in6_u.u6_addr32, 16);
    } else {
        return TC_ACT_OK; // Пропускаем ARP и прочее
    }

    struct user_state *state = bpf_map_lookup_elem(&user_state_map, &ip_k);
    __u64 now = bpf_ktime_get_ns();
    __u32 packet_len = skb->len;

    if (!state) {
        struct user_state new_state = {
            .window_start_time = now,
            .last_departure_time = now,
            .total_bytes = packet_len
        };
        bpf_map_update_elem(&user_state_map, &ip_k, &new_state, BPF_ANY);
        return TC_ACT_OK;
    }

    // Обновляем общую статистику
    __sync_fetch_and_add(&state->total_bytes, packet_len);

    // --- ЛОГИКА ДИНАМИЧЕСКОГО РЕЖИМА (Режим 2) ---
    if (conf->mode == 2) {
        if (state->is_penalized && now > state->penalty_end_time) {
            state->is_penalized = 0;
            state->window_start_time = now;
            state->bytes_in_window = 0;
        }

        if (!state->is_penalized) {
            if (now - state->window_start_time > conf->window_time_ns) {
                state->window_start_time = now;
                state->bytes_in_window = 0;
            }
            state->bytes_in_window += packet_len;
            if (state->bytes_in_window > conf->burst_bytes_limit) {
                state->is_penalized = 1;
                state->penalty_end_time = now + conf->penalty_time_ns;
            }
        }
    }

    // --- ЛОГИКА EDT (Плавное ограничение) ---
    __u64 current_rate = conf->normal_rate_bps;
    if (conf->mode == 2 && state->is_penalized) {
        current_rate = conf->penalty_rate_bps;
    }

    if (current_rate == 0) return TC_ACT_OK; // Безлимит

    // Рассчитываем, сколько наносекунд займет этот пакет при текущей скорости
    __u64 delay_ns = ((__u64)packet_len * 1000000000ULL) / current_rate;
    
    // Время отправки = максимум между "сейчас" и "временем отправки предыдущего"
    __u64 departure_time = state->last_departure_time;
    if (now > departure_time) {
        departure_time = now;
    }
    
    departure_time += delay_ns;

    // Защита от переполнения буфера (если пакет откладывается больше чем на 2 сек -> дроп)
    if (departure_time - now > 2000000000ULL) {
        return TC_ACT_SHOT; // Вот тут уже дропаем, так как канал забит наглухо
    }

    state->last_departure_time = departure_time;
    skb->tstamp = departure_time; // МАГИЯ EDT! Сообщаем ядру, когда отправить пакет

    return TC_ACT_OK;
}
